# HealthTribe Backend Environment Variables
# Copy this file to .env and fill in the values

# ===================================
# PROJECT CONFIGURATION
# ===================================
PROJECT_NAME=HealthTribe AI
API_V1_STR=/api/v1

# ===================================
# DATABASE (PostgreSQL) - REQUIRED
# ===================================
# For Render: Use the internal connection string from your Render Postgres service
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:PORT/DATABASE
POSTGRES_USER=healthtribe
POSTGRES_PASSWORD=your_secure_password_here
POSTGRES_DB=healthtribe_db
POSTGRES_HOST=localhost
POSTGRES_PORT=5432

# ===================================
# REDIS - OPTIONAL (not yet implemented)
# ===================================
# For future use with caching
# Format: redis://HOST:PORT/DB or redis://default:PASSWORD@HOST:PORT
# REDIS_URL=redis://localhost:6379/0

# ===================================
# CLERK AUTHENTICATION - REQUIRED
# ===================================
# Get these from https://dashboard.clerk.com/
CLERK_SECRET_KEY=sk_test_your_clerk_secret_key_here
CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Optional: For faster JWT verification (PEM format)
# CLERK_JWT_PUBLIC_KEY=""

# ===================================
# AI PROVIDERS - AT LEAST ONE REQUIRED
# ===================================
# GROQ (Recommended for fast inference)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# OpenRouter (Alternative)
# OPENROUTER_API_KEY=your_openrouter_api_key_here
# OPENROUTER_MODEL=openai/gpt-4o-mini

# Together AI (Alternative)
# TOGETHER_API_KEY=your_together_api_key_here
# TOGETHER_MODEL=meta-llama/Meta-Llama-3.1-70B-Instruct-Turbo

# ===================================
# DEPLOYMENT NOTES
# ===================================
# Render Deployment:
# 1. Create a Postgres database service
# 2. Create a Redis service (optional but recommended)
# 3. Add all REQUIRED variables above to your Web Service environment
# 4. Use internal connection strings for DATABASE and REDIS
# 5. Health check endpoint: /health
# 6. Port is automatically set by Render via $PORT
